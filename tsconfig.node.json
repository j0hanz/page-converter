{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"],
    "tsBuildInfoFile": ".next/cache/tsconfig.node.typecheck.tsbuildinfo"
  },
  "include": [
    "next.config.ts",
